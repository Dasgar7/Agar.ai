{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID." },
        "email": { "type": "string", "format": "email", "description": "User email address." },
        "displayName": { "type": "string", "description": "User display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "User profile photo URL." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created." }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique message ID." },
        "role": { "type": "string", "enum": ["user", "model"], "description": "Role of the sender." },
        "text": { "type": "string", "description": "Content of the message." },
        "timestamp": { "type": "number", "description": "When the message was sent." },
        "type": { "type": "string", "enum": ["text", "voice", "file"], "description": "Type of message." },
        "audioUrl": { "type": "string", "format": "uri", "description": "URL of the audio file." },
        "userAudioUrl": { "type": "string", "format": "uri", "description": "URL of the user's audio file." },
        "imageUrl": { "type": "string", "format": "uri", "description": "URL of the generated image." },
        "gameCode": { "type": "string", "description": "Generated game source code." },
        "model": { "type": "string", "description": "Model used for the message." }
      },
      "required": ["id", "role", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/users/{userId}/messages/{messageId}": {
      "schema": "Message",
      "description": "User chat history."
    }
  }
}
